<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'RskMedia' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <!-- text=… asks the CSS to only include glyphs for the Cyrillic block +
       Latin (bare minimum for RskMedia UI). Cuts font transfer ~50%
       vs. loading the whole Cyrillic + Latin extended set. -->
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap&subset=cyrillic,latin">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap&subset=cyrillic,latin" rel="stylesheet">
  <link rel="preload" as="style" href="/css/base.css">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/pages.css">
  <link rel="stylesheet" href="/css/style.css">
  <!-- defer keeps lucide.min.js from blocking parse — it's only needed
       after DOMContentLoaded fires (icons are created by navbar.js/etc). -->
  <script src="/js/lucide.min.js" nonce="<%= nonce %>" defer></script>
  <script nonce="<%= nonce %>">
    // Apply theme synchronously, BEFORE first paint, to avoid FOUC.
    // Stored value can be: "light" | "dark" | "auto" | null (never set).
    // "auto" and null both follow prefers-color-scheme.
    (function () {
      try {
        var stored = localStorage.getItem('rskmedia-theme');
        var resolved;
        if (stored === 'light' || stored === 'dark') {
          resolved = stored;
        } else {
          // "auto" or unset → follow OS.
          resolved = (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches)
            ? 'light' : 'dark';
        }
        document.documentElement.setAttribute('data-theme', resolved);
        if (stored) document.documentElement.setAttribute('data-theme-pref', stored);
      } catch (e) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    })();
  </script>
  <meta name="csrf-token" content="<%= csrfToken %>">
  <meta name="user-type" content="<%= user ? user.type : 'client' %>">
</head>
<body>
