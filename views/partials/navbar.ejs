<nav class="navbar" id="navbar">
  <div class="navbar-container">
    <a href="/" class="navbar-logo">RskMedia</a>
    <button class="navbar-toggle" id="navbarToggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="navbar-menu" id="navbarMenu">
      <a href="/" class="navbar-link <%= activePage === 'home' ? 'active' : '' %>">
        <i data-lucide="home" class="icon-md"></i>
        Главная
      </a>
      <a href="/favorites" class="navbar-link <%= activePage === 'favorites' ? 'active' : '' %>">
        <i data-lucide="heart" class="icon-md"></i>
        Избранное
      </a>
      <a href="/collections" class="navbar-link <%= activePage === 'collections' ? 'active' : '' %>">
        <i data-lucide="library" class="icon-md"></i>
        Коллекции
      </a>
      <button class="navbar-link navbar-theme-toggle" id="themeToggle" aria-label="Сменить тему" title="Сменить тему">
        <!-- CSS shows one icon based on data-theme-pref (light/dark/auto). -->
        <i data-lucide="sun" class="navbar-theme-icon navbar-theme-icon-light"></i>
        <i data-lucide="moon" class="navbar-theme-icon navbar-theme-icon-dark"></i>
        <i data-lucide="monitor" class="navbar-theme-icon navbar-theme-icon-auto"></i>
      </button>
      <% if (user && user.type === 'admin') { %>
      <a href="/admin" class="navbar-link navbar-link-admin <%= activePage === 'admin' ? 'active' : '' %>">
        <i data-lucide="shield" class="icon-md"></i>
        Админ
      </a>
      <% } %>
      <% if (user) { %>
      <button class="navbar-link navbar-btn" id="logoutBtn">
        <i data-lucide="log-out" class="icon-md"></i>
        Выход
      </button>
      <% } %>
    </div>
  </div>
</nav>
<!-- defer so it runs AFTER the deferred lucide.min.js: both are scheduled
     at DOMContentLoaded and defer preserves document order. -->
<script src="/js/navbar.js" nonce="<%= nonce %>" defer></script>
