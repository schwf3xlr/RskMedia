

<div class="page-container">
  <div class="pull-to-refresh" id="pullToRefresh" aria-hidden="true">
    <div class="pull-to-refresh-icon"><i data-lucide="refresh-cw" class="icon-md"></i></div>
    <div class="pull-to-refresh-text">Потяните вниз для обновления</div>
  </div>
  <div class="filters">
    <div class="filters-row">
      <select class="filter-select" id="categoryFilter">
        <option value="">Все категории</option>
      </select>
      <select class="filter-select" id="subcategoryFilter">
        <option value="">Все подкатегории</option>
      </select>
      <select class="filter-select" id="ageFilter">
        <option value="">Все возраста</option>
        <% for(let i of AGE_RATINGS) { %>
        <option value="<%= i %>"><%= i >= 19 ? i + '+' : i %></option>
        <% } %>
      </select>
      <select class="filter-select" id="sortFilter">
        <option value="newest">Новые</option>
        <option value="oldest">Старые</option>
        <option value="name">По имени</option>
        <option value="photos">Фото</option>
        <option value="videos">Видео</option>
        <option value="random">Случайно</option>
        <option value="age_desc">По возрасту ↓</option>
        <option value="age_asc">По возрасту ↑</option>
      </select>
      <button class="btn btn-primary" id="applyFilters">
        <i data-lucide="filter" class="icon-md"></i>
        Применить
      </button>
      <button class="btn btn-secondary" id="clearFilters">
        <i data-lucide="x" class="icon-md"></i>
        Сбросить
      </button>
    </div>
  </div>

  <div class="media-grid" id="mediaGrid" role="list" aria-label="Медиа галерея"></div>
  <div class="loading-spinner hidden" id="loadingSpinner">
    <div class="spinner"></div>
  </div>
  <div class="empty-state hidden" id="emptyState">
    <div class="empty-state-icon"><i data-lucide="image" class="icon-lg"></i></div>
    <div class="empty-state-title" id="emptyTitle">Галерея пуста</div>
    <div class="empty-state-text" id="emptyText">Загрузите медиа через админ-панель</div>
  </div>
  <div class="sentinel" id="sentinel"></div>
</div>

<button class="back-to-top" id="backToTop" aria-label="Наверх" title="Наверх">
  <i data-lucide="arrow-up" class="icon-md"></i>
</button>

<div class="modal" id="mediaModal" role="dialog" aria-modal="true" aria-label="Просмотр медиа" tabindex="-1">
  <div class="modal-overlay" id="modalOverlay"></div>
  <div class="modal-media-full" id="modalMediaContainer"></div>
  <button class="modal-close" id="modalClose" aria-label="Закрыть">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
  </button>
  <% if (user && user.type === 'admin') { %>
  <button class="modal-edit" id="modalEdit" aria-label="Редактировать медиа">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
  </button>
  <div class="modal-edit-panel" id="modalEditPanel" hidden>
    <div class="edit-panel-content" role="dialog" aria-modal="true" aria-label="Редактирование медиа">
      <div class="edit-panel-header">
        <span class="edit-panel-title">Редактировать медиа</span>
        <button class="edit-panel-close" id="editPanelClose" aria-label="Закрыть">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <div class="edit-panel-body">
        <label class="edit-field">
          <span class="edit-field-label">Категория</span>
          <select id="editCategory" class="edit-field-select">
            <option value="">Без категории</option>
          </select>
        </label>
        <label class="edit-field">
          <span class="edit-field-label">Подкатегория</span>
          <select id="editSubcategory" class="edit-field-select">
            <option value="">Без подкатегории</option>
          </select>
        </label>
        <label class="edit-field">
          <span class="edit-field-label">Возраст</span>
          <select id="editAge" class="edit-field-select">
            <option value="">Не указан</option>
            <% for(let i of AGE_RATINGS) { %>
            <option value="<%= i %>"><%= i >= 19 ? i + '+' : i %></option>
            <% } %>
          </select>
        </label>
      </div>
      <div class="edit-panel-footer">
        <button class="btn btn-danger btn-delete-media" id="editDelete">
          <i data-lucide="trash-2" class="icon-md"></i>
          Удалить
        </button>
        <div class="edit-panel-footer-right">
          <button class="btn btn-secondary" id="editCancel">Отмена</button>
          <button class="btn btn-primary" id="editSave">Сохранить</button>
        </div>
      </div>
    </div>
  </div>
  <% } %>
  <button class="modal-nav modal-prev" id="modalPrev" aria-label="Предыдущее">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
  </button>
  <button class="modal-nav modal-next" id="modalNext" aria-label="Следующее">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
  </button>
  <div class="modal-bottom-bar">
    <span class="modal-age" id="modalAge"></span>
    <button class="modal-favorite" id="modalFavorite" aria-label="Добавить в избранное">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
      </svg>
    </button>
  </div>
</div>

<script src="/js/player.js" type="module" nonce="<%= nonce %>"></script>
