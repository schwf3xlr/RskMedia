<%- include('partials/header', { title: 'Админ - RskMedia' }) %>
<%- include('partials/navbar', { activePage: 'admin', user: user }) %>

<div class="page-container">
  <input type="hidden" id="currentTokenId" value="<%= user.token_id %>">
  <div class="page-header">
    <div>
      <h1 class="page-title">Админ-панель</h1>
      <p class="page-subtitle">Управление медиа, токенами, категориями и бэкапами</p>
    </div>
  </div>



  <div class="admin-tabs">
    <button class="admin-tab active" data-tab="upload">
      <i data-lucide="upload-cloud" class="icon-md"></i>
      Загрузка
    </button>
    <button class="admin-tab" data-tab="batch">
      <i data-lucide="sliders-horizontal" class="icon-md"></i>
      Редактирование
    </button>
    <button class="admin-tab" data-tab="categories">
      <i data-lucide="folder-tree" class="icon-md"></i>
      Категории
    </button>
    <button class="admin-tab" data-tab="tokens">
      <i data-lucide="key-round" class="icon-md"></i>
      Токены
    </button>
    <button class="admin-tab" data-tab="backup">
      <i data-lucide="database" class="icon-md"></i>
      Бэкап
    </button>
    <button class="admin-tab" data-tab="duplicates">
      <i data-lucide="copy" class="icon-md"></i>
      Дубликаты
    </button>
  </div>

  <div class="admin-panel active" id="uploadPanel">
    <div class="upload-card">
      <div class="upload-card-title">
        <i data-lucide="upload" class="icon-md"></i>
        Одиночная загрузка
      </div>
      <form class="upload-form" id="singleUploadForm">
        <div class="file-drop-zone" id="singleDropZone">
          <div class="file-drop-zone-text">
            <i data-lucide="image-plus" class="icon-lg icon-accent mb-1"></i><br>
            <strong>Перетащите файл</strong> или нажмите для выбора
          </div>
          <div class="file-drop-zone-sub">JPG, PNG, GIF, WEBP, MP4, MOV до <%= process.env.MAX_FILE_SIZE_MB || 500 %> МБ</div>
          <input type="file" id="singleFile" class="file-input-hidden" accept="image/*,video/*" required>
        </div>
        <div class="upload-form-row">
          <select class="filter-select" id="singleCategory">
            <option value="">Категория</option>
          </select>
          <select class="filter-select" id="singleSubcategory">
            <option value="">Подкатегория</option>
          </select>
          <select class="filter-select" id="singleAge">
            <option value="">Возраст</option>
            <% for(let i of AGE_RATINGS) { %>
            <option value="<%= i %>"><%= i >= 19 ? i + '+' : i %></option>
            <% } %>
          </select>
          <button type="submit" class="btn btn-primary">
            <i data-lucide="upload" class="icon-md"></i>
            Загрузить
          </button>
        </div>
      </form>
      <div class="progress-bar hidden" id="singleProgress">
        <div class="progress-fill" id="singleProgressFill"></div>
      </div>
    </div>

    <div class="upload-card">
      <div class="upload-card-title">
        <i data-lucide="gallery-horizontal" class="icon-md"></i>
        Множественная загрузка
      </div>
      <form class="upload-form" id="batchUploadForm">
        <div class="file-drop-zone" id="batchDropZone">
          <div class="file-drop-zone-text">
            <i data-lucide="folder-plus" class="icon-lg icon-accent mb-1"></i><br>
            <strong>Перетащите файлы</strong> или нажмите для выбора
          </div>
          <div class="file-drop-zone-sub">До <%= process.env.MAX_BATCH_FILES || 100 %> файлов за раз</div>
          <input type="file" id="batchFiles" class="file-input-hidden" multiple accept="image/*,video/*" required>
        </div>
        <div class="upload-form-row">
          <select class="filter-select" id="batchCategory">
            <option value="">Категория</option>
          </select>
          <select class="filter-select" id="batchSubcategory">
            <option value="">Подкатегория</option>
          </select>
          <select class="filter-select" id="batchAge">
            <option value="">Возраст</option>
            <% for(let i of AGE_RATINGS) { %>
            <option value="<%= i %>"><%= i >= 19 ? i + '+' : i %></option>
            <% } %>
          </select>
          <button type="submit" class="btn btn-primary">
            <i data-lucide="upload" class="icon-md"></i>
            Загрузить
          </button>
          <button type="button" class="btn btn-secondary hidden" id="cancelBatchUpload">
            <i data-lucide="x" class="icon-md"></i>
            Отмена
          </button>
        </div>
      </form>
      <div class="upload-queue" id="uploadQueue"></div>
    </div>
  </div>

  <div class="admin-panel" id="batchPanel">
    <div class="batch-filter-bar">
      <span class="batch-filter-label">Показать только:</span>
      <label class="batch-filter-chip">
        <input type="checkbox" class="admin-missing-filter" data-field="category_id">
        <span>Без категории</span>
      </label>
      <label class="batch-filter-chip">
        <input type="checkbox" class="admin-missing-filter" data-field="subcategory_id">
        <span>Без подкатегории</span>
      </label>
      <label class="batch-filter-chip">
        <input type="checkbox" class="admin-missing-filter" data-field="age_rating">
        <span>Без возраста</span>
      </label>
    </div>
    <div class="batch-actions-bar">
      <span class="selected-count" id="selectedCount">Выбрано: 0</span>
      <button class="btn btn-sm" id="selectAllBtn">
        <i data-lucide="check-square" class="icon-sm"></i>
        Выбрать всё
      </button>
      <select class="filter-select" id="batchSetCategory">
        <option value="">Установить категорию</option>
      </select>
      <select class="filter-select" id="batchSetSubcategory">
        <option value="">Установить подкатегорию</option>
      </select>
      <select class="filter-select" id="batchSetAge">
        <option value="">Установить возраст</option>
        <% for(let i of AGE_RATINGS) { %>
        <option value="<%= i %>"><%= i >= 19 ? i + '+' : i %></option>
        <% } %>
      </select>
      <button class="btn btn-primary" id="applyBatch">
        <i data-lucide="check" class="icon-md"></i>
        Применить
      </button>
      <button class="btn btn-danger" id="deleteBatch">
        <i data-lucide="trash-2" class="icon-md"></i>
        Удалить
      </button>
    </div>
    <div class="admin-media-grid" id="mediaCards"></div>
    <div class="admin-grid-footer">
      <div class="admin-grid-sentinel" id="adminGridSentinel"></div>
    </div>
  </div>

  <div class="admin-panel" id="categoriesPanel">
    <div class="upload-card">
      <div class="upload-card-title">Добавить категорию</div>
      <div class="category-form">
        <input type="text" class="category-input" id="newCategoryName" placeholder="Название категории">
        <button class="btn btn-primary" id="createCategoryBtn">
          <i data-lucide="plus" class="icon-md"></i>
          Добавить
        </button>
      </div>
    </div>
    <div class="upload-card">
      <div class="upload-card-title">Добавить подкатегорию</div>
      <div class="category-form">
        <select id="newSubcategoryCategory" class="filter-select">
          <option value="">Выберите категорию</option>
        </select>
        <input type="text" class="category-input" id="newSubcategoryName" placeholder="Название подкатегории">
        <button class="btn btn-primary" id="createSubcategoryBtn">
          <i data-lucide="plus" class="icon-md"></i>
          Добавить
        </button>
      </div>
    </div>
    <div class="table-container mt-3">
      <div class="table-responsive">
        <table class="admin-table" id="categoriesTable">
          <thead>
            <tr>
              <th>Категория</th>
              <th>Подкатегории</th>
              <th>Действия</th>
            </tr>
          </thead>
          <tbody id="categoriesTableBody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="admin-panel" id="tokensPanel">
    <div class="table-container">
      <div class="token-form">
        <select id="tokenType" class="filter-select" required>
          <option value="client">Client</option>
          <option value="admin">Admin</option>
        </select>
        <input type="date" id="tokenExpires" placeholder="Срок действия (опционально)">
        <button type="button" class="btn btn-primary" id="createTokenBtn">
          <i data-lucide="plus" class="icon-md"></i>
          Создать токен
        </button>
      </div>
      <div class="table-responsive">
        <table class="admin-table" id="tokensTable">
          <thead>
            <tr>
              <th>Токен</th>
              <th>Тип</th>
              <th>Создан</th>
              <th>Истекает</th>
              <th>Статус</th>
              <th>Действия</th>
            </tr>
          </thead>
          <tbody id="tokensTableBody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="admin-panel" id="backupPanel">
    <div class="upload-card">
      <div class="upload-card-title">
        <i data-lucide="download" class="icon-md icon-inline"></i>
        Скачать бэкап
      </div>
      <p class="card-description">
        Скачать все данные базы данных (категории, подкатегории, токены, медиа, избранное) в JSON-файл
      </p>
      <button class="btn btn-primary" id="backupBtn">
        <i data-lucide="download" class="icon-md"></i>
        Скачать бэкап
      </button>
    </div>

    <div class="upload-card">
      <div class="upload-card-title">
        <i data-lucide="upload" class="icon-md icon-inline"></i>
        Восстановить из бэкапа
      </div>
      <p class="card-description warning">
        Внимание: текущие данные будут полностью заменены. Это действие необратимо.
      </p>
      <div class="file-drop-zone mb-2" id="restoreDropZone">
        <div class="file-drop-zone-text">
          <i data-lucide="file-json" class="icon-xl icon-warning mb-2"></i><br>
          <strong>Выберите JSON-файл бэкапа</strong>
        </div>
        <div class="file-drop-zone-sub">.json, до 50 МБ</div>
        <input type="file" id="restoreFile" class="file-input-hidden" accept=".json">
      </div>
      <div id="restoreStatus" class="hidden mb-2"></div>
      <button class="btn btn-danger" id="restoreBtn" disabled>
        <i data-lucide="refresh-cw" class="icon-md"></i>
        Восстановить
      </button>
    </div>
  </div>

  <div class="admin-panel" id="duplicatesPanel">
    <div class="upload-card">
      <div class="upload-card-title">
        <i data-lucide="search" class="icon-md"></i>
        Поиск дубликатов
      </div>
      <p class="card-description">
        Поиск медиа с похожими обложками. Для точных результатов сначала вычислить хеши для всех медиа.
      </p>
      <button class="btn btn-primary" id="findDuplicatesBtn">
        <i data-lucide="search" class="icon-md"></i>
        Найти дубликаты
      </button>
      <div class="progress-bar hidden mt-2" id="duplicatesProgress">
        <div class="progress-fill" id="duplicatesProgressFill"></div>
      </div>
      <div id="duplicatesStatus" class="mt-2"></div>
    </div>
    <div id="duplicatesResults"></div>
  </div>
</div>

<script src="/js/admin.js" type="module" nonce="<%= nonce %>"></script>
<%- include('partials/footer') %>
