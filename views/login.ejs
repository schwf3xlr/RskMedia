<%- include('partials/header', { title: 'Login - RskMedia' }) %>

<div class="login-page">
  <div class="login-container">
    <div class="login-card">
      <h1 class="login-logo">RskMedia</h1>
      <p class="login-subtitle">Введите ваш токен для входа</p>
      <form class="login-form" id="loginForm">
        <div class="login-input-wrapper">
          <i data-lucide="key" class="login-input-icon"></i>
          <input type="password" class="login-input" id="tokenInput" placeholder="Ваш токен (client_... или admin_...)" required autocomplete="off">
        </div>
        <button type="submit" class="login-btn">
          <i data-lucide="arrow-right" class="icon-md"></i>
          Войти
        </button>
      </form>
      <p class="login-error" id="loginError"></p>
    </div>
  </div>
</div>

<script nonce="<%= nonce %>">
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.getRegistrations().then(registrations => {
      registrations.forEach(reg => reg.unregister());
    });
    if ('caches' in window) {
      caches.keys().then(names => names.forEach(name => caches.delete(name)));
    }
  }
</script>

<script src="/js/login.js" type="module" nonce="<%= nonce %>"></script>

<%- include('partials/footer') %>
