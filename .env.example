# Server
PORT=3000
NODE_ENV=development

# Security
TRUST_PROXY=1
CORS_ORIGIN=http://localhost:3000
COOKIE_SECRET=change_me_in_production

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rskmedia
DB_USER=postgres
DB_PASSWORD=your_password
DB_SSL=false

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES=7d

# S3 Storage (Beget)
S3_ENDPOINT=https://s3.beget.com
S3_REGION=ru-1
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET=rskmedia
S3_URL_CACHE_TTL=3300
S3_URL_CACHE_MAX=5000

# Upload
MAX_FILE_SIZE_MB=500
MAX_PHOTO_SIZE_MB=50
MAX_VIDEO_SIZE_MB=500
MAX_BATCH_FILES=100

# Rate limits
API_RATE_LIMIT=300
UPLOAD_RATE_LIMIT=50
ADMIN_RATE_LIMIT=200

# Optimizations
SIGN_URL_EXPIRES=3600
MEDIA_PAGE_SIZE=20
ADMIN_PAGE_SIZE=50
